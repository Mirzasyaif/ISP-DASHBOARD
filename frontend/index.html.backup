<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#2563EB">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="ISP Dashboard">
    <title>ISP Management Dashboard</title>
    <link rel="stylesheet" href="assets/css/output.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .status-active { background-color: #10B981; }
        .status-inactive { background-color: #EF4444; }
        .card { transition: transform 0.2s; }
        .card:hover { transform: translateY(-2px); }
        
        /* Loading animations */
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .animate-spin {
            animation: spin 1s linear infinite;
        }
        
        /* Mobile optimizations */
        @media (max-width: 768px) {
            .responsive-table {
                display: block;
                overflow-x: auto;
            }
            .table-cell-compact {
                padding: 6px 8px;
                font-size: 14px;
            }
            /* Touch-friendly buttons */
            button {
                min-height: 44px;
                min-width: 44px;
            }
            /* Better tap targets */
            input, select {
                min-height: 44px;
            }
            /* Prevent text selection on mobile */
            .no-select {
                -webkit-user-select: none;
                -moz-user-select: none;
                -ms-user-select: none;
                user-select: none;
            }
        }
        
        /* Safe area for notched phones */
        .safe-area-top {
            padding-top: env(safe-area-inset-top);
        }
        .safe-area-bottom {
            padding-bottom: env(safe-area-inset-bottom);
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navbar -->
    <nav class="bg-blue-600 text-white p-4 shadow safe-area-top">
        <div class="container mx-auto flex justify-between items-center">
            <div class="flex items-center space-x-4 md:space-x-6">
                <h1 class="text-xl md:text-2xl font-bold">ISP Dashboard</h1>
                <button id="mobile-menu-button" class="md:hidden focus:outline-none">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <div class="hidden md:flex space-x-4">
                    <a href="index.html" class="px-3 py-2 rounded hover:bg-blue-700 transition">Dashboard</a>
                    <a href="secrets.html" class="px-3 py-2 rounded hover:bg-blue-700 transition">All Secrets</a>
                    <a href="settings.html" class="px-3 py-2 rounded hover:bg-blue-700 transition">Settings</a>
                </div>
            </div>
            <div class="space-x-2 md:space-x-4">
                <span id="live-status" class="px-2 md:px-3 py-1 bg-green-500 rounded-full text-sm md:text-base">● Live</span>
                <button onclick="refreshData()" class="px-3 md:px-4 py-2 bg-blue-700 rounded hover:bg-blue-800 text-sm md:text-base">Refresh</button>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="md:hidden hidden mt-4 bg-blue-700 rounded-lg">
            <div class="flex flex-col space-y-2 p-4">
                <a href="index.html