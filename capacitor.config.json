{
  "appId": "com.isp.dashboard",
  "appName": "ISP Dashboard",
  "webDir": "frontend",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "buildOptions": {
      "keystorePath": "android/keystore.jks",
      "keystoreAlias": "isp-dashboard"
    }
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}